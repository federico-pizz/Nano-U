# ── Python / build artifacts ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.coverage
.cache/
.pytest_cache/
.mypy_cache/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv*/
venv/
env/
ENV/

# ── IDE / editor / OS ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Run outputs & local config (only the public template is tracked) ─────────
results/
config/*.yaml
config/*.yml
!config/config.yaml

# ── Media & data blobs (tracked exceptions whitelisted further down) ─────────
*.png
*.jpg
*.jpeg
*.rgb
*.tif
*.tiff
*.json

# ── Rust ─────────────────────────────────────────────────────────────────────
/target/
**/target/
Cargo.lock
!firmware/Cargo.lock
firmware/.cargo/*
!firmware/.cargo/config.toml
firmware/models/*.tflite

# ── tools/: ignore scratch, keep committed figures ──────────────────────────
tools/**
!tools/
!tools/figure_2.png
!tools/predictions_comparison.png
!tools/tinyagri_grid.png

# ── Docs: keep READMEs, ignore other markdown drafts ────────────────────────
*.md
!README.md
